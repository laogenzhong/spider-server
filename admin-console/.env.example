# 两条远程 spider-server HTTPS 线路，不要带 /admin-console。
# 本地代理会并发探测 /ping，自动使用可用且更快的一条；保留旧的
# ADMIN_SERVER_URL 仅用于兼容单线路配置。
ADMIN_SERVER_URL_LINE1=https://xajk.top
ADMIN_SERVER_URL_LINE2=https://jjai.top

# 与服务端 admin.console_secret 相同，至少 32 字节。不要添加 VITE_ 前缀。
ADMIN_CONSOLE_SECRET=replace-with-at-least-32-random-characters

# 可选。本地主库默认保存在 ~/.lifttags-admin/offer-codes.json。
LIFTTAGS_OFFER_STORE_PATH=

# 必填。客户端项目根目录；动作库与探索编辑器会从这里读取当前动作、GIF 和本地化名称。
SPIDER_CLIENT_ROOT=/absolute/path/to/spider

# 可选。客户端 ExerciseGIFs 目录；默认使用 SPIDER_CLIENT_ROOT/spider/Resources/ExerciseGIFs。
EXERCISE_GIF_ROOT=
